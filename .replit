modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
ADMIN_EMAILS = "aserafin@gmail.com"
EMAIL_FROM = "admin@contact.schoolstack.ai"
REVIEW_NOTIFY_EMAIL = "hello@schoolstack.ai"
VITE_GA_MEASUREMENT_ID = "G-BYCDHVP29R"

[userenv.development]

[nix]
channel = "stable-25_05"
